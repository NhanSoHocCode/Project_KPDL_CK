# 05_association_rules.ipynb

"""
================================================================================
PHÂN TÍCH LUẬT KẾT HỢP - ASSOCIATION RULES MINING
================================================================================
Mục tiêu: Tìm ra các mối quan hệ và quy tắc kết hợp giữa các sản phẩm/dịch vụ
         mà khách hàng đang sử dụng, từ đó đề xuất chiến lược cross-selling
         và up-selling hiệu quả.

Thuật toán sử dụng:
1. Apriori: Thuật toán kinh điển, dễ hiểu, phù hợp với dữ liệu nhỏ
2. FP-Growth: Thuật toán tối ưu, nhanh hơn Apriori, phù hợp với dữ liệu lớn

Tác giả: Data Science Team
Năm: 2024
================================================================================
"""

# ==============================================================================
# 1. IMPORT THƯ VIỆN & CẤU HÌNH
# ==============================================================================

import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from mlxtend.frequent_patterns import apriori, fpgrowth, association_rules
from collections import Counter
import warnings
warnings.filterwarnings('ignore')

# Cấu hình hiển thị
plt.rcParams['figure.figsize'] = (12, 8)
plt.rcParams['font.size'] = 12
sns.set_theme(style='whitegrid', palette='Set2')

# ==============================================================================
# 2. ĐỌC VÀ KHÁM PHÁ DỮ LIỆU
# ==============================================================================

df = pd.read_csv('../data/BankChurners_cleaned.csv')
print("="*70)
print("THÔNG TIN DỮ LIỆU BAN ĐẦU")
print("="*70)
print(f"Kích thước dataset: {df.shape[0]} khách hàng x {df.shape[1]} thuộc tính")
print(f"\nCác cột có sẵn: {list(df.columns)}")

# ==============================================================================
# 3. LỰA CHỌN ĐẶC TRƯNG CHO PHÂN TÍCH LUẬT KẾT HỢP
# ==============================================================================

"""
Các biến được sử dụng cho phân tích luật kết hợp:

1. Categorical variables (cần one-hot encoding):
   - Gender: Giới tính (Nam/Nữ)
   - Education_Level: Trình độ học vấn
   - Income_Category: Hạng mục thu nhập
   - Card_Category: Hạng thẻ tín dụng
   - Marital_Status: Tình trạng hôn nhân

2. Numerical variables (cần phân bin/discretize):
   - Customer_Age: Độ tuổi
   - Credit_Limit: Hạn mức tín dụng
   - Total_Trans_Ct: Số lượng giao dịch
   - Total_Relationship_Count: Số lượng sản phẩm
"""

# 3.1. Xử lý biến phân loại (Categorical)
categorical_cols = ['Gender', 'Education_Level', 'Income_Category', 'Card_Category']

# Mã hóa các biến phân loại
for col in categorical_cols:
    print(f"\nGiá trị duy nhất của {col}: {df[col].unique()}")

# 3.2. Tạo các nhóm cho biến số (Discretization)
# Phân nhóm độ tuổi
df['Age_Group'] = pd.cut(df['Customer_Age'], 
                         bins=[0, 30, 40, 50, 60, 100],
                         labels=['<30', '30-40', '40-50', '50-60', '>60'])

# Phân nhóm hạn mức tín dụng
df['Credit_Group'] = pd.cut(df['Credit_Limit'],
                            bins=[0, 5000, 15000, 30000, 100000],
                            labels=['Thấp', 'Trung bình', 'Cao', 'Rất cao'])

# Phân nhóm số lượng giao dịch
df['Trans_Group'] = pd.cut(df['Total_Trans_Ct'],
                           bins=[0, 30, 50, 70, 200],
                           labels=['Ít', 'Trung bình', 'Nhiều', 'Rất nhiều'])

# Phân nhóm số lượng sản phẩm
df['Product_Group'] = pd.cut(df['Total_Relationship_Count'],
                             bins=[0, 2, 4, 6, 10],
                             labels=['Ít', 'Trung bình', 'Nhiều', 'Rất nhiều'])

# Phân nhóm tỷ lệ sử dụng hạn mức
df['Utilization_Group'] = pd.cut(df['Avg_Utilization_Ratio'],
                                 bins=[-0.1, 0.2, 0.4, 0.6, 0.8, 1.1],
                                 labels=['Rất thấp', 'Thấp', 'Trung bình', 'Cao', 'Rất cao'])

# Phân nhóm thời gian không hoạt động
df['Inactive_Group'] = pd.cut(df['Months_Inactive_12_mon'],
                              bins=[-1, 0, 1, 2, 3, 6],
                              labels=['Hoạt động', '1 tháng', '2 tháng', '3 tháng', '>3 tháng'])

print("\n" + "="*70)
print("CÁC NHÓM ĐÃ TẠO CHO PHÂN TÍCH LUẬT KẾT HỢP")
print("="*70)
print(f"- Age_Group: {df['Age_Group'].cat.categories.tolist()}")
print(f"- Credit_Group: {df['Credit_Group'].cat.categories.tolist()}")
print(f"- Trans_Group: {df['Trans_Group'].cat.categories.tolist()}")
print(f"- Product_Group: {df['Product_Group'].cat.categories.tolist()}")
print(f"- Utilization_Group: {df['Utilization_Group'].cat.categories.tolist()}")
print(f"- Inactive_Group: {df['Inactive_Group'].cat.categories.tolist()}")

# ==============================================================================
# 4. TẠO BẢNG GIAO DỊCH (TRANSACTION DATASET)
# ==============================================================================

print("\n" + "="*70)
print("TẠO BẢNG GIAO DỊCH CHO PHÂN TÍCH LUẬT KẾT HỢP")
print("="*70)

# Danh sách các cột sẽ sử dụng cho phân tích
transaction_columns = [
    'Gender', 'Education_Level', 'Income_Category', 'Card_Category',
    'Age_Group', 'Credit_Group', 'Trans_Group', 'Product_Group',
    'Utilization_Group', 'Inactive_Group'
]

# Tạo bảng giao dịch (mỗi hàng là một khách hàng, mỗi cột là một item)
transaction_df = df[transaction_columns].copy()

# Thêm thông tin về trạng thái rời bỏ (để phân tích)
transaction_df['Attrition'] = df['Attrition_Flag'].map({0: 'Trung thành', 1: 'Rời bỏ'})

print(f"\nKích thước bảng giao dịch: {transaction_df.shape}")
print(f"Số lượng items mỗi giao dịch: {transaction_df.shape[1]}")
print("\n5 giao dịch đầu tiên:")
display(transaction_df.head())

# ==============================================================================
# 5. ONE-HOT ENCODING (CHUYỂN ĐỔI DỮ LIỆU)
# ==============================================================================

print("\n" + "="*70)
print("ONE-HOT ENCODING - CHUYỂN ĐỔI DỮ LIỆU")
print("="*70)

# Thực hiện one-hot encoding
transaction_encoded = pd.get_dummies(transaction_df, prefix_sep='_')
print(f"Kích thước sau one-hot encoding: {transaction_encoded.shape}")
print(f"Số lượng items (features): {transaction_encoded.shape[1]}")

# Hiển thị một số cột
print("\nCác cột sau one-hot encoding:")
display(transaction_encoded.iloc[:, :10].head())

# ==============================================================================
# 6. THUẬT TOÁN APRIORI
# ==============================================================================

print("\n" + "="*70)
print("THUẬT TOÁN 1: APRIORI - TÌM TẬP PHỔ BIẾN")
print("="*70)

"""
Giải thích các tham số:
- min_support: Ngưỡng hỗ trợ tối thiểu (tần suất xuất hiện của itemset)
- use_colnames: Sử dụng tên cột thay vì chỉ số
- max_len: Độ dài tối đa của itemset
"""

# Thử nghiệm với các ngưỡng support khác nhau
min_support_values = [0.05, 0.1, 0.15, 0.2]
results_apriori = {}

for min_sup in min_support_values:
    print(f"\n🔍 Đang chạy Apriori với min_support = {min_sup}...")
    
    # Tìm frequent itemsets
    frequent_itemsets = apriori(transaction_encoded, 
                                min_support=min_sup, 
                                use_colnames=True,
                                verbose=0)
    
    n_itemsets = len(frequent_itemsets)
    print(f"   ✅ Tìm thấy {n_itemsets} frequent itemsets")
    
    if n_itemsets > 0:
        # Tạo luật kết hợp
        rules = association_rules(frequent_itemsets, metric="lift", min_threshold=1.0)
        n_rules = len(rules)
        print(f"   ✅ Tạo được {n_rules} luật kết hợp")
        results_apriori[min_sup] = {'itemsets': frequent_itemsets, 'rules': rules}
    else:
        results_apriori[min_sup] = {'itemsets': None, 'rules': None}

# Chọn ngưỡng support tối ưu (thường chọn min_support = 0.1)
OPTIMAL_SUPPORT = 0.1
print(f"\n✅ Chọn min_support = {OPTIMAL_SUPPORT} cho phân tích chính")

frequent_itemsets_apriori = results_apriori[OPTIMAL_SUPPORT]['itemsets']
rules_apriori = results_apriori[OPTIMAL_SUPPORT]['rules']

print(f"\n📊 KẾT QUẢ APRIORI (min_support={OPTIMAL_SUPPORT}):")
print(f"   • Số frequent itemsets: {len(frequent_itemsets_apriori)}")
print(f"   • Số luật kết hợp: {len(rules_apriori)}")

# ==============================================================================
# 7. THUẬT TOÁN FP-GROWTH
# ==============================================================================

print("\n" + "="*70)
print("THUẬT TOÁN 2: FP-GROWTH - TỐI ƯU CHO DỮ LIỆU LỚN")
print("="*70)

"""
FP-Growth (Frequent Pattern Growth) là thuật toán cải tiến của Apriori:
- Không cần sinh candidate itemsets
- Chỉ quét dữ liệu 2 lần
- Nhanh hơn Apriori đáng kể với dữ liệu lớn
"""

results_fpgrowth = {}

for min_sup in min_support_values:
    print(f"\n🔍 Đang chạy FP-Growth với min_support = {min_sup}...")
    
    frequent_itemsets = fpgrowth(transaction_encoded, 
                                  min_support=min_sup, 
                                  use_colnames=True)
    
    n_itemsets = len(frequent_itemsets)
    print(f"   ✅ Tìm thấy {n_itemsets} frequent itemsets")
    
    if n_itemsets > 0:
        rules = association_rules(frequent_itemsets, metric="lift", min_threshold=1.0)
        n_rules = len(rules)
        print(f"   ✅ Tạo được {n_rules} luật kết hợp")
        results_fpgrowth[min_sup] = {'itemsets': frequent_itemsets, 'rules': rules}
    else:
        results_fpgrowth[min_sup] = {'itemsets': None, 'rules': None}

frequent_itemsets_fpgrowth = results_fpgrowth[OPTIMAL_SUPPORT]['itemsets']
rules_fpgrowth = results_fpgrowth[OPTIMAL_SUPPORT]['rules']

print(f"\n📊 KẾT QUẢ FP-GROWTH (min_support={OPTIMAL_SUPPORT}):")
print(f"   • Số frequent itemsets: {len(frequent_itemsets_fpgrowth)}")
print(f"   • Số luật kết hợp: {len(rules_fpgrowth)}")

# ==============================================================================
# 8. SO SÁNH APRIORI VS FP-GROWTH
# ==============================================================================

print("\n" + "="*70)
print("SO SÁNH HIỆU SUẤT APRIORI VS FP-GROWTH")
print("="*70)

import time

# Đo thời gian chạy Apriori
start_time = time.time()
apriori(transaction_encoded, min_support=0.05, use_colnames=True)
apriori_time = time.time() - start_time

# Đo thời gian chạy FP-Growth
start_time = time.time()
fpgrowth(transaction_encoded, min_support=0.05, use_colnames=True)
fpgrowth_time = time.time() - start_time

comparison_df = pd.DataFrame({
    'Tiêu chí': ['Thời gian xử lý', 'Cách thức hoạt động', 'Bộ nhớ sử dụng', 'Phù hợp với'],
    'Apriori': [
        f'{apriori_time:.4f} giây',
        'Sinh candidate itemsets',
        'Nhiều',
        'Dữ liệu nhỏ (< 10,000 giao dịch)'
    ],
    'FP-Growth': [
        f'{fpgrowth_time:.4f} giây',
        'Xây dựng FP-Tree',
        'Ít hơn',
        'Dữ liệu lớn (> 10,000 giao dịch)'
    ]
})

display(comparison_df)

print(f"\n📊 NHẬN XÉT:")
if fpgrowth_time < apriori_time:
    print(f"   ✅ FP-Growth nhanh hơn Apriori {(apriori_time/fpgrowth_time):.2f} lần")
else:
    print(f"   ✅ Apriori nhanh hơn FP-Growth {(fpgrowth_time/apriori_time):.2f} lần")

# ==============================================================================
# 9. PHÂN TÍCH LUẬT KẾT HỢP CHI TIẾT
# ==============================================================================

print("\n" + "="*70)
print("PHÂN TÍCH LUẬT KẾT HỢP CHI TIẾT")
print("="*70)

# Chọn luật từ FP-Growth (kết quả tốt hơn)
rules = rules_fpgrowth.copy()

# Thêm các chỉ số đánh giá
rules['antecedent_len'] = rules['antecedents'].apply(len)
rules['consequent_len'] = rules['consequents'].apply(len)
rules['rule_length'] = rules['antecedent_len'] + rules['consequent_len']

# Sắp xếp theo lift (độ tin cậy của luật)
rules_sorted = rules.sort_values('lift', ascending=False)

print("\n📊 TOP 10 LUẬT CÓ LIFT CAO NHẤT:")
top_rules = rules_sorted.head(10)[['antecedents', 'consequents', 'support', 'confidence', 'lift']]
display(top_rules)

# ==============================================================================
# 10. LỌC LUẬT THEO CÁC TIÊU CHÍ
# ==============================================================================

print("\n" + "="*70)
print("LỌC LUẬT THEO CÁC TIÊU CHÍ")
print("="*70)

# 10.1. Luật có confidence cao (độ tin cậy > 0.7)
high_conf_rules = rules[rules['confidence'] > 0.7].sort_values('confidence', ascending=False)
print(f"\n🔍 LUẬT CÓ CONFIDENCE > 0.7: {len(high_conf_rules)} luật")
display(high_conf_rules.head(10))

# 10.2. Luật có lift cao (lift > 2)
high_lift_rules = rules[rules['lift'] > 2].sort_values('lift', ascending=False)
print(f"\n🔍 LUẬT CÓ LIFT > 2: {len(high_lift_rules)} luật")
display(high_lift_rules.head(10))

# 10.3. Luật có support cao (support > 0.15)
high_sup_rules = rules[rules['support'] > 0.15].sort_values('support', ascending=False)
print(f"\n🔍 LUẬT CÓ SUPPORT > 0.15: {len(high_sup_rules)} luật")
display(high_sup_rules.head(10))

# ==============================================================================
# 11. PHÂN TÍCH LUẬT THEO NHÓM KHÁCH HÀNG
# ==============================================================================

print("\n" + "="*70)
print("PHÂN TÍCH LUẬT THEO NHÓM KHÁCH HÀNG")
print("="*70)

# 11.1. Luật cho khách hàng TRUNG THÀNH
print("\n📋 LUẬT CHO KHÁCH HÀNG TRUNG THÀNH:")

# Lọc các luật có chứa 'Trung thành' trong consequent
loyal_rules = rules[rules['consequents'].apply(lambda x: 'Trung thành' in str(x))]
loyal_rules = loyal_rules.sort_values('lift', ascending=False)

if len(loyal_rules) > 0:
    print(f"\n   Tìm thấy {len(loyal_rules)} luật liên quan đến khách hàng trung thành")
    display(loyal_rules.head(10))
    
    # Trích xuất các yếu tố đặc trưng
    antecedents_list = []
    for ants in loyal_rules.head(10)['antecedents']:
        for item in ants:
            antecedents_list.append(item)
    
    common_features = Counter(antecedents_list).most_common(5)
    print("\n   🏆 ĐẶC ĐIỂM CỦA KHÁCH HÀNG TRUNG THÀNH:")
    for feature, count in common_features:
        print(f"      • {feature} (xuất hiện trong {count} luật)")
else:
    print("   Không tìm thấy luật nào")

# 11.2. Luật cho khách hàng RỜI BỎ
print("\n📋 LUẬT CHO KHÁCH HÀNG RỜI BỎ:")

churn_rules = rules[rules['consequents'].apply(lambda x: 'Rời bỏ' in str(x))]
churn_rules = churn_rules.sort_values('lift', ascending=False)

if len(churn_rules) > 0:
    print(f"\n   Tìm thấy {len(churn_rules)} luật liên quan đến khách hàng rời bỏ")
    display(churn_rules.head(10))
    
    antecedents_list = []
    for ants in churn_rules.head(10)['antecedents']:
        for item in ants:
            antecedents_list.append(item)
    
    common_features = Counter(antecedents_list).most_common(5)
    print("\n   ⚠️ ĐẶC ĐIỂM CỦA KHÁCH HÀNG RỜI BỎ:")
    for feature, count in common_features:
        print(f"      • {feature} (xuất hiện trong {count} luật)")
else:
    print("   Không tìm thấy luật nào")

# ==============================================================================
# 12. TRỰC QUAN HÓA LUẬT KẾT HỢP
# ==============================================================================

print("\n" + "="*70)
print("TRỰC QUAN HÓA LUẬT KẾT HỢP")
print("="*70)

# 12.1. Biểu đồ phân tán Support vs Confidence
fig, axes = plt.subplots(1, 2, figsize=(14, 6))

# Support vs Confidence
scatter = axes[0].scatter(rules['support'], rules['confidence'], 
                          c=rules['lift'], cmap='viridis', 
                          alpha=0.6, s=50)
axes[0].set_xlabel('Support', fontsize=12)
axes[0].set_ylabel('Confidence', fontsize=12)
axes[0].set_title('Support vs Confidence (màu sắc theo Lift)', fontsize=14)
plt.colorbar(scatter, ax=axes[0], label='Lift')

# Support vs Lift
scatter2 = axes[1].scatter(rules['support'], rules['lift'], 
                           c=rules['confidence'], cmap='plasma', 
                           alpha=0.6, s=50)
axes[1].set_xlabel('Support', fontsize=12)
axes[1].set_ylabel('Lift', fontsize=12)
axes[1].set_title('Support vs Lift (màu sắc theo Confidence)', fontsize=14)
plt.colorbar(scatter2, ax=axes[1], label='Confidence')

plt.tight_layout()
plt.show()

# 12.2. Histogram phân phối các chỉ số
fig, axes = plt.subplots(1, 3, figsize=(15, 5))

axes[0].hist(rules['support'], bins=20, color='steelblue', edgecolor='black')
axes[0].set_xlabel('Support', fontsize=12)
axes[0].set_ylabel('Tần suất', fontsize=12)
axes[0].set_title('Phân phối Support', fontsize=14)

axes[1].hist(rules['confidence'], bins=20, color='coral', edgecolor='black')
axes[1].set_xlabel('Confidence', fontsize=12)
axes[1].set_ylabel('Tần suất', fontsize=12)
axes[1].set_title('Phân phối Confidence', fontsize=14)

axes[2].hist(rules['lift'], bins=20, color='green', edgecolor='black')
axes[2].set_xlabel('Lift', fontsize=12)
axes[2].set_ylabel('Tần suất', fontsize=12)
axes[2].set_title('Phân phối Lift', fontsize=14)

plt.tight_layout()
plt.show()

# 12.3. Top luật theo Lift (dạng thanh)
top_20_rules = rules_sorted.head(20).copy()
top_20_rules['rule_str'] = top_20_rules['antecedents'].apply(lambda x: ', '.join(list(x))) + ' → ' + \
                           top_20_rules['consequents'].apply(lambda x: ', '.join(list(x)))

plt.figure(figsize=(12, 8))
bars = plt.barh(range(len(top_20_rules)), top_20_rules['lift'], color='steelblue')
plt.yticks(range(len(top_20_rules)), top_20_rules['rule_str'], fontsize=9)
plt.xlabel('Lift', fontsize=12)
plt.title('TOP 20 LUẬT KẾT HỢP CÓ LIFT CAO NHẤT', fontsize=14)
plt.gca().invert_yaxis()
plt.tight_layout()
plt.show()

# ==============================================================================
# 13. PHÂN TÍCH LUẬT THEO SẢN PHẨM (CROSS-SELLING)
# ==============================================================================

print("\n" + "="*70)
print("PHÂN TÍCH CROSS-SELLING - LUẬT KẾT HỢP GIỮA CÁC SẢN PHẨM")
print("="*70)

# Lọc các luật liên quan đến Card_Category
card_rules = rules[rules['antecedents'].apply(lambda x: any('Card_Category' in str(item) for item in x)) |
                   rules['consequents'].apply(lambda x: any('Card_Category' in str(item) for item in x))]

if len(card_rules) > 0:
    print(f"\n📊 Tìm thấy {len(card_rules)} luật liên quan đến hạng thẻ")
    display(card_rules.sort_values('lift', ascending=False).head(10))
    
    # Đề xuất cross-selling
    print("\n💡 ĐỀ XUẤT CROSS-SELLING DỰA TRÊN LUẬT KẾT HỢP:")
    
    for idx, row in card_rules.head(5).iterrows():
        antecedents = ', '.join(list(row['antecedents']))
        consequents = ', '.join(list(row['consequents']))
        print(f"\n   • NẾU khách hàng có: {antecedents}")
        print(f"     → THÌ nên giới thiệu: {consequents}")
        print(f"     → Độ tin cậy: {row['confidence']:.2%}, Lift: {row['lift']:.2f}")

# ==============================================================================
# 14. ĐỀ XUẤT CHIẾN LƯỢC KINH DOANH
# ==============================================================================

print("\n" + "="*70)
print("🏆 ĐỀ XUẤT CHIẾN LƯỢC KINH DOANH")
print("="*70)

# Tổng hợp các luật quan trọng
important_rules = rules[
    (rules['confidence'] > 0.6) & 
    (rules['lift'] > 1.5) & 
    (rules['support'] > 0.05)
].sort_values('lift', ascending=False)

print(f"\n📊 Tổng hợp {len(important_rules)} luật quan trọng (confidence>0.6, lift>1.5, support>0.05)")

# Phân loại theo loại khách hàng
print("\n" + "="*70)
print("📋 KHUYẾN NGHỊ THEO NHÓM KHÁCH HÀNG")
print("="*70)

recommendations = {
    '🎯 CHIẾN LƯỢC GIỮ CHÂN KHÁCH HÀNG TRUNG THÀNH': [
        '✅ Duy trì và phát huy các yếu tố tích cực đã phát hiện',
        '✅ Tặng quà tri ân cho khách hàng có nhiều sản phẩm',
